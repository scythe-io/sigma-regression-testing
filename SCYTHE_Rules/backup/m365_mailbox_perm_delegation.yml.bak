title: Suspicious Mailbox Permission Delegation
id: 539170d6-ea17-493c-a3fb-4dc7f04f1042
status: experimental
description: Detects mailbox permission delegation.
references:
    - https://support.scythe.io/knowledge/m365
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024/03/27
tags:
    - attack.persistence
    - attack.1098.002
logsource:
    product: m365
    service: threat_management
detection:
    selection:
        EventSource:
            - UnifiedAuditLog
        Operation|contains: 
            - 'Add owner to application'
            - 'delegate mailbox permissions'
    condition: selection
falsepositives:
    - Normal mailbox permission delegation.
level: 
    - medium
