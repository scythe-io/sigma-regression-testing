title: Filesystem Deletions related to ALPHV/Blackcat 
id: c8b86c71-f113-493c-8624-1052f7b94550
status: experimental
description: Detects virtual machines, snapshots, windows event log, and shadow copy deletion related to ALPHV Blackcat C2.
references:
  - https://www.varonis.com/blog/blackcat-ransomware
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024/01/03
tags:
  - attack.T1485
  - attack.T1490
logsource:
  product: windows
  service: sysmon
detection:
  selection:
    EventID: 1 
  filter:
    CommandLine|contains:
      - 'esxcli vm process kill --type=force' 
      - 'do vim-cmd vmsvc/snapshot.removeall'
      - 'vssadmin.exe delete shadows'
      - 'wevtutil.exe cl'
  condition: selection and filter
falsepositives:
 - Legitimate system administration tasks may use similar commands.
level: high
