title: Kimsuky Keylogger File Creation
id: 31C7B1F5-3C88-4B19-8A5E-937C27C40158
status: experimental
description: Detect any file operations containing desktops.ini
author: Jarrad Pemberton - Scythe
date: 2025/06/26
logsource:
    product: windows
detection:
    selection:
        - TargetFilename|contains: 'desktops.ini'
        - target_filename|contains: 'desktops.ini'
        - file_path|contains: 'desktops.ini'
        - ObjectName|contains: 'desktops.ini'
        - object_name|contains: 'desktops.ini'
        - file_name|contains: 'desktops.ini'
    condition: selection
level: medium