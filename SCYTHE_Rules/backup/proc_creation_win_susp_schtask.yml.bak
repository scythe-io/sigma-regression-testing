title: Suspicious Scheduled Task Creation
id: 1c001601-0563-4458-99c2-7addad4fe601
status: experimental
description: Detects suspicious scheduled task creation by filtering on commandline parameters.
references:
    - https://support.scythe.io/knowledge/empower-threat-feb2024-coldriver-spica
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024-02-28
tags:
    - attack.execution
    - attack.persistence
    - attack.t1059
    - attack.t1053
logsource:
    product: windows
    service: process_creation
detection:
    selection_img:
        Image|endswith: 
            - '\powershell.exe'
            - '\cmd.exe'
    selection_cmdline:
        - CommandLine|contains:
            - "New-ScheduledTask"
            - "SCHTASKS* /CREATE"
            - " at "
            - " at.exe "
        - Message|contains:
            - "New-ScheduledTask"
            - "SCHTASKS* /CREATE"
    condition: all of selection_*
falsepositives:
    - Administrators may utilize powershell to create scheduled tasks.  
level: medium
