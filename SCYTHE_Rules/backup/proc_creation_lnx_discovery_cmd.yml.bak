title: Linux Discovery by Suspicious Process
id: bee3c1ea-8508-48b8-b641-cffbefd45e3d
status: experimental
description: Detects linux discovery commandline arguments that are not spawned from typical user shells, such as "bash" or "sh".
references:
    -  https://unit42.paloaltonetworks.com/new-linux-variant-bifrost-malware/
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024/03/18
tags:
    - attack.execution
    - attack.1059.004
logsource:
    product: linux
    category: process_creation
detection:
    selection_cmdline:
        CommandLine|contains:
            - 'ip '
            - 'ss '
            - 'hostname'
    selection_shell:
        ParentImage|contains: #Modify this to include standard shells in your env.
            - '/bin/bash'
            - '/bin/sh'
            - '/bin/zsh'
    condition: selection_cmdline NOT selection_shell
falsepositives:
    - Administrators utilize these commands for regular work duties. 
level: low
