title: Kimsuky Keylogger Detection
id: a1b2c3d4-e5f6-7890-abcd-ef1234567890
status: experimental
description: Detects Kimsuky keylogger activity including klogexe.exe execution and suspicious file creation targeting desktops.ini in APPDATA paths
author: Jarrad Pemberton Scythe
date: 2025/06/26
modified: 2025/06/26
tags:
    - attack.credential_access
    - attack.t1056.001  # Keylogging
    - attack.collection
    - attack.t1005      # Data from Local System
    - kimsuky.apt
references:
    - https://www.trendmicro.com/vinfo/us/threat-encyclopedia/malware/trojanspy.win32.fpspy.thicobd
logsource:
    category: process_creation
    product: windows
detection:
    # Keylogger process execution
    selection_klogexe:
        - Image|endswith: '\klogexe.exe'
        - OriginalFileName: 'klogexe.exe'
        - CommandLine|contains: 'klogexe'
    
    filter_legitimate_processes:
        Image|endswith:
            - '\explorer.exe'
            - '\winlogon.exe'
            - '\dwm.exe'
    
    condition: selection_klogexe and not filter_legitimate_processes
    
falsepositives:
    - Legitimate desktop configuration tools
    - System administration activities
    
level: high

fields:
    - Image
    - CommandLine
    - ParentImage
    - ParentCommandLine
    - ProcessId
    - User