title: Domain Discovery via NET
id: 4b512931-574c-4faf-a579-af1040f6d8db
status: experimental
description: Detects domain discovery via net group /domain commands.
references:
  - https://www.mandiant.com/resources/blog/session-hijacking-citrix-cve-2023-4966
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024-02-13
tags:
  - attack.discovery
  - attack.t1069.002
  - attack.t1087.002
logsource:
  product: windows
  service: proc_creation
detection:
  selection_1:
    - Image|endswith: "net.exe"
    - Image|endswith: "net1.exe"
  selection_2:
    CommandLine|contains:
      - "admins"
      - "users"
      - "computers"
      - "/domain"
  condition: all of selection_*
falsepositives:
 - Administrator activity
level: medium
