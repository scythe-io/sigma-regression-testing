title: Registry Modifications Related to LockBitv3 Ransomware
status: experimental
id: bbe4ab32-4862-4227-a607-0f68f5bae418
description: Detects modifying registry keys to enable smart screen, allow auto logon, and disable Windows Event Logging.
references:
 - https://www.cisa.gov/news-events/cybersecurity-advisories/aa23-075a
 - https://www.ultimatewindowssecurity.com/securitylog/encyclopedia/event.aspx?eventid=90013
author: Tyler Casey @1qazCasey, @scythe_io
date: 2023/12/21
tags:
 - attack.TA0003 
 - attack.T1547
 - attack.TA0005
 - attack.T1562.002
logsource:
 product: windows
 service: sysmon
detection:
 selection_base:
   EventID: 13
 selection1:
   TargetObject|contains:
     - '\SOFTWARE\Policies\Microsoft\Windows\System\EnableSmartScreen'
   Details|contains: '0'
 selection2:
   TargetObject|contains:
     - '\SOFTWARE\Microsoft\Windows\CurrentVersion\WINEVT\Channels\*\Enabled'
   Details|contains: '0'
 selection3:
   TargetObject|contains:
     - '\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon\AutoAdminLogon'
   Details|contains: '1'
 selection4:
   TargetObject|contains:
     - '\SOFTWARE\Policies\Microsoft\Windows Defender\Real-Time Protection\DisableRealtimeMonitoring'
   Details|contains: '1'
 selection5:
   TargetObject|contains:
     - '\SOFTWARE\Policies\Microsoft\WindowsFirewall\*Profile\EnableFirewall'
   Details|contains: '0'
 condition: selection_base and (selection1 or selection2 or selection3 or selection4 or selection5)
falsepositives:
 - Legitimate system administration tasks may use similar commands.
level: high