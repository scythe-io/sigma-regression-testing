title: Process Execution from Windows SxS
id: b3157617-7d1d-43db-8990-16ca0a1e9d18
status: experimental
description: Detects process execution origination from the Windows SxS (side-by-side) directory.  
references:
    - https://support.scythe.io/knowledge/april-2024-winsxs-sideloading
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024/04/22
tags:
    - attack.execution
    - attack.t1059.001
logsource:
    product: windows
    category: proc_creation 
detection:
    selection_parent_img:
        ParentImage|contains:
            - 'Windows\WinSxs'
    selection_img:
        Image|contains:
            - 'Windows\WinSxs'    
    selection_exc: #Place known good SxS Process Images here
        Image|endswith:
            - '\TiWorker.exe'
    condition: selection_parent_img or selection_img) not selection_exc
falsepositives:
    - Legitimate processes executing from Windows SxS directory.
level: 
    - medium