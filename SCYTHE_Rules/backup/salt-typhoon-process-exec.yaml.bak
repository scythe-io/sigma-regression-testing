title: Salt Typhoon Process Execution Behaviors
id: 1a2b3c4d-5e6f-7a8b-9c0d-1e2f3a4b5c6d
status: experimental
description: Detects Salt Typhoon campaign process execution including CAB extraction, registry imports, and PowerShell service creation
references:
    - https://www.sygnia.co/blog/ghost-emperor-demodex-rootkit/
author: Jarrad Pemberton - SCYTHE
date: 2025/01/18
tags:
    - attack.execution
    - attack.t1059.001
    - attack.t1059.003
    - attack.defense_evasion
    - attack.t1027.002
    - attack.persistence
    - attack.t1543.003
logsource:
    category: process_creation
    product: windows
detection:
    selection_cab_extract:
        Image|endswith:
            - '\expand.exe'
            - '\extrac32.exe'
        CommandLine|contains: '.cab'
    selection_reg_import:
        Image|endswith: '\reg.exe'
        CommandLine|contains|all:
            - 'import'
            - '.REG'
    selection_powershell_bypass:
        Image|endswith: '\powershell.exe'
        CommandLine|contains|all:
            - '-ex bypass'
            - '.ps1'
    condition: 1 of selection_*
falsepositives:
    - Administrative CAB extraction and registry operations
    - Legitimate PowerShell script execution with bypass policy
level: medium