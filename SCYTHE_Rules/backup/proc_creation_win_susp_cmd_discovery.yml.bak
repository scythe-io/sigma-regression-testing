title: Suspicious Discovery CMD
id: 8e2ad471-257f-49f3-8e45-0da1ec8a62b9
status: experimental
description: Detects suspicious discovery commands that are not spawned from cmd or powershell.  
references:
    -   https://support.scythe.io/knowledge/march-2024-ioc-applejeus
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024/03/13
tags:
    - attack.discovery
    - attack.1033
    - attack.t1016
logsource:
    product: windows
    category: proc_creation
detection:
    selection_img:
        Image|endswith:
            - '\whoami.exe'
            - '\ipconfig.exe'
            - '\hostname.exe'
    selection_parent_img:
        ParentImage|endswith: 
            - '\cmd.exe'
            - '\powershell.exe'
            - '\powershell_ise.exe'
    condition: selection_img not selection_parent_img
falsepositives:
    - Unknown
level: 
    - medium