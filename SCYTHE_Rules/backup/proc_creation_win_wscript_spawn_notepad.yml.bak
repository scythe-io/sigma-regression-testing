title: Wscript executing Notepad++
id: c3e0bc2a-f4f4-4913-b852-e719a4967ba6
status: experimental
description: Detects wscript.exe executing Notepad++, this behavior is associated with Pikabot malware.
references:
    - https://support.scythe.io/knowledge/empower-1-feb2024-pikabot
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024/02/27
tags:
    - attack.execution
    - attack.t1059
logsource:
    product: windows
    service: proc_creation
detection:
    selection_parent_img:
        ParentImage|endswith:
            - '\cmd.exe'
            - '\wscript.exe'
    selection_process:
        - Image|endswith:
            - '\notepad++.exe'
        - CommandLine|contains:
            - 'notepad++.exe'
    condition: all of selection_*
falsepositives:
    - Unknown
level: high
