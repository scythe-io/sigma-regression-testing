title: SharePoint CVE-2025-53770 Target URI Enumeration
id: a1b2c3d4-e5f6-7890-1234-567890abcdef
status: experimental
description: Detects enumeration of specific SharePoint URIs commonly targeted prior to CVE-2025-53770 exploitation attempts, including automated scanning patterns and multiple endpoint probing
references:
    - https://nvd.nist.gov/vuln/detail/CVE-2025-53770
author: Jarrad Pemberton - SCYTHE
date: 2025-01-24
tags:
    - attack.reconnaissance
    - attack.t1590.002
    - attack.discovery
    - attack.t1083
    - cve.2025-53770
logsource:
    category: webserver
detection:
    selection_primary_targets:
        cs_uri_stem|endswith:
            - '/_layouts/15/settings.aspx'
            - '/_layouts/15/ToolPane.aspx'
    selection_recon_methods:
        cs_method:
            - 'HEAD'
            - 'GET'
            - 'OPTIONS'
    selection_automation_indicators:
        cs_user_agent|contains:
            - 'curl/'
            - 'python-requests'
            - 'Wget/'
            - 'Mozilla/5.0 (compatible;'
    selection_standard_ports:
        s_port:
            - 80
            - 443
    timeframe: 5m
    condition: 
        selection_primary_targets and 
        selection_recon_methods or 
        selection_standard_ports or 
        selection_automation_indicators
falsepositives:
    - Legitimate SharePoint health monitoring
    - Authorized SharePoint administration tools
level: medium