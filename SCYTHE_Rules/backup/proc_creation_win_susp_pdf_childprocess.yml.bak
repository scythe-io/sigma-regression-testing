title: Suspicious Process by PDF
id: 9e1ab35a-abc8-48f7-8b9e-320da08bed16
status: experimental
description: Detects potentially suspicious processes being spawned from a PDF.
references:
    - https://support.scythe.io/knowledge/empower-threat-feb2024-coldriver-spica
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024/02/28
tags:
    - attack.execution
    - attack.t1059
    - attack.t1204.002
logsource:
    product: windows
    service: process_creation
detection:
    selection_parent_img:
        ParentImage|endswith: #Common pdf viewers
            - '\msedge.exe'
            - '\acrord32.exe'
            - '\foxitreader.exe'
            - '\sumatrapdf.exe'
    selection_parentcmd:
        ParentCommandLine|contains:
            - '.pdf'
    selection_img:
        Image|endswith:
            - '\cmd.exe'
            - '\powershell.exe'
    condition: all of selection_*
falsepositives:
    - Unknown
level: high
