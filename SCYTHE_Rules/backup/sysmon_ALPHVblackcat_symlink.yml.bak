title: Enabling Remote and Local Symlink
id: d864ec41-1b8f-41b0-9cbe-7c6f677b5bfa
status: experimental
description: Detects enabling of symlinks for remote to remote and remote to local related to ALPHV Blackcat C2.
references:
  - https://www.varonis.com/blog/blackcat-ransomware
author: Tyler Casey @1qazCasey, @scythe_io
date: 2024/01/03
tags:
  - attack.T1059
  - attack.TA0008
logsource:
  product: windows
  service: sysmon
detection:
  selection:
    EventID: 1 
  filter:
    CommandLine|contains:
      - 'fsutil behavior set SymlinkEvaluation R2L:1'
      - 'fsutil behavior set SymlinkEvaluation R2R:1'
  condition: selection and filter
falsepositives:
  - Unusual user behavior
level: high
