title: Salt Typhoon Malicious WdiSystem Service Creation
id: 8c4f2a91-3d5e-4f7b-9a2c-1e8d7c6b5a94
status: test
description: Detects the creation of a malicious WdiSystem service that masquerades as a legitimate Windows Diagnostic service, associated with Salt Typhoon threat actor tactics for persistence
references:
    - https://www.sygnia.co/blog/ghost-emperor-demodex-rootkit/
author: Jarrad Pemberton - SCYTHE
date: 2025-01-21
tags:
    - attack.persistence
    - attack.t1543.003
    - attack.defense_evasion
    - attack.t1036.005
logsource:
    product: windows
    service: sysmon
detection:
    selection_wdisystem:
        - CommandLine|contains: 'WdiSystem'
        - TargetObject|contains: 'WdiSystem'
        - TargetFilename|contains: 'WdiSystem'
    
    selection_prints1m:
        - CommandLine|contains: 'prints1m'
        - TargetObject|contains: 'prints1m'
        - TargetFilename|contains: 'prints1m'
        - Details|contains: 'prints1m'
    
    selection_wdisystemhost:
        - CommandLine|contains: 'WdiSystemhost'
        - TargetObject|contains: 'WdiSystemhost'
        - Details|contains: 'WdiSystemhost'
    
    selection_wdisystem_parameters_registry:
        EventID: 12
        TargetObject|contains: '\Services\WdiSystem\Parameters'
    
    condition: 1 of selection_*
falsepositives:
    - Legitimate Windows Diagnostic Infrastructure service creation (extremely rare)
    - Administrative scripts creating legitimate diagnostic services
level: high